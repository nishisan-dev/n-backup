@startuml architecture
!theme plain
skinparam backgroundColor #FEFEFE
skinparam componentStyle rectangle
skinparam defaultFontName Inter

title NBackup — Arquitetura Geral

package "Origem (Agent - Daemon)" as agent {
  [Scheduler\n(Cron Expression)] as scheduler
  [Scanner\n(fs.WalkDir + Glob)] as scanner
  [tar.Writer] as tar
  [gzip.Writer\n(pgzip parallel)] as gzip
  [SHA-256\n(io.TeeReader)] as hash_client
  [RingBuffer\n(256MB, backpressure)] as rb
  [Dispatcher\n(round-robin chunks)] as dispatcher
  [AutoScaler\n(hysteresis scaling)] as autoscaler
  [ControlChannel\n(PING/PONG, RTT)] as control
  [TLS Client\n(mTLS)] as tls_client
  [Config Loader\n(YAML)] as config
  [Logger\n(slog JSON)] as logger_a
  [Retry Engine\n(Exp. Backoff)] as retry
  [Throttle\n(Token Bucket)] as throttle
  [Monitor\n(CPU/Mem/Disk)] as monitor
  [DSCP\n(QoS marking)] as dscp
  [Progress\n(--once bar)] as progress
  [StatsReporter\n(→ Control Channel)] as stats

  config --> scheduler
  config --> scanner
  scheduler --> scanner : trigger
  scanner --> tar : files
  tar --> gzip : io.Pipe
  gzip --> hash_client : io.TeeReader
  hash_client --> rb : stream
  rb --> dispatcher : chunks
  dispatcher --> tls_client : ChunkHeader + DATA
  autoscaler ..> dispatcher : scale up/down
  throttle ..> tls_client : rate limit
  dscp ..> tls_client : QoS
  retry --> tls_client : reconnect
  monitor ..> stats : sys metrics
  stats ..> control : report to server
  control --> tls_client : keep-alive
}

cloud "Rede\n(TCP + TLS 1.3)" as network

package "Destino (Server)" as server {
  [TLS Server\n(mTLS)] as tls_server
  [Protocol Handler\n(modularizado)] as proto
  [SHA-256\n(io.MultiWriter)] as hash_server
  [ChunkAssembler\n(parallel reassembly)] as assembler
  [ChunkBuffer\n(in-memory staging)] as chunkbuf
  [Storage Writer\n(.tmp → rename)] as storage
  [Rotation Manager\n(max_backups)] as rotation
  [Integrity\n(VerifyArchive)] as integrity
  [PostCommitOrchestrator\n(Object Storage)] as pco
  [SyncStorage\n(retroactive sync)] as sync_storage
  [Slot\n(estado tipado)] as slot
  [Observability\n(WebUI + REST + Prometheus)] as obs
  [Config Loader\n(YAML)] as config_s
  [Logger\n(slog JSON)] as logger_s

  tls_server --> proto : conexão aceita
  proto --> chunkbuf : chunks paralelos
  chunkbuf --> assembler : drain
  proto --> hash_server : single stream
  hash_server --> storage : io.Copy
  assembler --> storage : finalize
  storage --> integrity : verify_integrity
  integrity --> rotation : se válido
  rotation --> pco : após rotação
  pco --> sync_storage : sync mode
  config_s --> rotation
  config_s --> tls_server
  slot ..> proto : estado por stream
}

cloud "Object Storage\n(S3-compatible)" as s3

tls_client --> network
network --> tls_server
pco --> s3 : Upload (multipart)
sync_storage --> s3 : Retroactive sync

admin ..> obs : HTTP :9848\n(WebUI + REST + Prometheus)
obs ..> proto : snapshots\n(métricas, sessões)

note right of network
  Protocolo binário NBKP
  ~60 bytes overhead por sessão
  Payload: tar.gz/tar.zst stream raw
  Porta: 9847/tcp
end note

note bottom of storage
  Escrita atômica:
  1. Grava em .tmp
  2. Valida SHA-256
  3. Rename atômico
  4. Rotação (remove antigos)
end note

note bottom of scanner
  Respeita regras de
  include/exclude (glob)
  do arquivo YAML
end note
@enduml
