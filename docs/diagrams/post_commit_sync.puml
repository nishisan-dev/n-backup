@startuml post_commit_sync
!theme plain

title Fluxo Pós-Commit — Object Storage

actor Agent
participant "Handler\n(Single/Parallel)" as Handler
participant "AtomicWriter" as AW
participant "IntegrityVerifier" as IV
participant "Rotate" as Rotate
participant "PostCommitOrchestrator" as PCO
participant "S3Backend\n(sync)" as Sync
participant "S3Backend\n(offload)" as Offload
participant "S3Backend\n(archive)" as Archive
database "S3 Bucket" as S3

== Commit Atômico ==

Handler -> AW: Commit(tmpPath)
AW --> Handler: finalPath

== Verificação de Integridade (opcional) ==

opt verify_integrity: true
  Handler -> IV: VerifyArchiveIntegrity(finalPath)
  IV -> IV: Descomprime e valida tar entries\n(gzip ou zstd conforme extensão)
  alt Integridade OK
    IV --> Handler: nil
  else Integridade falhou
    IV --> Handler: error
    Handler -> Handler: Abort — não rotaciona\n(preserva backups anteriores)
    Handler -> Agent: **FINAL ACK** [INTEGRITY_ERROR]
  end
end

== Rotação Local ==

Handler -> Rotate: Rotate(agentDir, maxBackups)
Rotate --> Handler: []removedFiles

== Async Upload Check ==

alt async_upload: true (sync/archive)
  Handler -> Agent: **FINAL ACK** [OK]
  note right
    Lock liberado — agent pode
    iniciar novo backup imediatamente
  end note
  Handler -> PCO: Execute(finalPath, removedFiles, agentDir)\n[goroutine background]
else async_upload: false (default) ou offload
  Handler -> PCO: Execute(finalPath, removedFiles, agentDir)
end

== Object Storage Pós-Commit ==

activate PCO

group Paralelo (goroutines)

  group sync
    alt sync_strategy: safe (default)
      PCO -> Sync: Upload(finalPath)
      note right
        Upload primeiro (redundância imediata)
        S3 Manager Uploader (multipart)
      end note
      Sync -> S3: CreateMultipartUpload\n+ UploadPart(s) + CompleteMultipart
      S3 --> Sync: OK
      loop para cada removedFile
        PCO -> Sync: Delete(removedFile)
        Sync -> S3: DeleteObject
      end
    else sync_strategy: space_efficient
      loop para cada removedFile
        PCO -> Sync: Delete(removedFile)
        note right: Delete primeiro\n(libera espaço no bucket)
        Sync -> S3: DeleteObject
      end
      PCO -> Sync: Upload(finalPath)
      Sync -> S3: CreateMultipartUpload\n+ UploadPart(s) + CompleteMultipart
      S3 --> Sync: OK
    end
  end

  group offload (blocking)
    PCO -> Offload: Upload(finalPath)
    Offload -> S3: CreateMultipartUpload\n+ UploadPart(s) + CompleteMultipart
    S3 --> Offload: OK
    Offload -> Offload: os.Remove(local)
    PCO -> Offload: List(prefix)
    Offload -> S3: ListObjectsV2
    note right: Rotate via retain\n(remove excedentes)
    loop se len > retain
      PCO -> Offload: Delete(oldest)
    end
  end

  group archive (fire-and-forget)
    loop para cada removedFile
      PCO -> Archive: Upload(removedFile)
      Archive -> S3: CreateMultipartUpload\n+ UploadPart(s) + CompleteMultipart
    end
    PCO -> Archive: List(prefix)
    note right: Rotate via retain
    loop se len > retain
      PCO -> Archive: Delete(oldest)
    end
  end

end

alt Upload falhou após retries
  PCO -> Sync: AbortIncompleteUploads(prefix)
  note right
    Cleanup de parts órfãs no bucket
    Evita acúmulo de lixo (multipart incompletos)
  end note
end

PCO --> Handler: []PostCommitResult
deactivate PCO

== FinalACK (se síncrono) ==

opt async_upload: false (ou offload)
  Handler -> Agent: FinalACK(OK)
end

note over Handler
  offload bloqueia até upload confirmado
  sync e archive são fire-and-forget
  async_upload: true libera lock e ACK antes do sync
  Stall detection: cancela upload se inativo > stall_timeout
end note

@enduml

